// Online C compiler to run C program online
// Read n number and print
#include <stdio.h>

int main() {
    // This programm reads and print 20 number
    int i=0,num=0;
    //Thid block will read 20 number form user
    for(i=0;i<20;i++){
        printf("please enter number %d\n",i+1);
        scanf("%d",&num);
    }
    // This block will print 20 number entered by user
    printf("number you entered are");
    for(i=0;i<20;i++){
        printf("number %d is %d\n",i+1,&num);
    }

    return 0;
}